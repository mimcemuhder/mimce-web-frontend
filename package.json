{
  "name": "mimce-engineering-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:supabase": "tsx scripts/verifySupabaseSetup.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.91.1",
